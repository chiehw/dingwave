# 复制为 .env 后按本机填写（.env 已被 .gitignore，勿提交真实密钥）
# 在仓库根执行 ./dingwave 时由程序自动加载；命令行参数优先于环境变量。

# 源库路径（对应 -d）
DINGWAVE_D=dingtalk.db

# V2：目录 uid；V3：real_uid（对应 -k，勿用目录名当 uid）
DINGWAVE_K=

# V3：与 -userconfig 相同，user_config 文件路径
# DINGWAVE_USERCONFIG=/path/to/DingTalk/xxx_v3/user_config

# V3：若不用 user_config 文件，可改用 salt（对应 -salt）
# DINGWAVE_SALT=

# 解密结果输出路径（对应 -o）
DINGWAVE_O=dingtalk_decrypted.db

# HTTP 端口（对应 -p；留空则程序内默认 8080）
DINGWAVE_P=8080

# 合并库路径（对应 -merged-out）
# DINGWAVE_MERGED_OUT=.agents/skills/dingwave-messages/cache/merged.db

# 仅导出合并库后退出（对应 -export-only：1 / true / yes / on）
# DINGWAVE_EXPORT_ONLY=

# 拉取图片（对应 -token）
# DINGWAVE_TOKEN=
